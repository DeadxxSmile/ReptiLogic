{
  "name": "reptilogic",
  "version": "0.2.0",
  "description": "Desktop collection and breeding manager for reptile keepers",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"wait-on http://127.0.0.1:5173 && npm run dev:electron\"",
    "dev": "npm run start",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['node_modules','dist','build','.vite','package-lock.json']) { try { fs.rmSync(p,{recursive:true,force:true}); console.log('removed',p) } catch (e) {} }\""
  },
  "dependencies": {
    "better-sqlite3": "12.9.0",
    "date-fns": "4.1.0",
    "electron-store": "11.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.3",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@vitejs/plugin-react": "5.0.4",
    "concurrently": "9.2.1",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "vite": "7.1.7",
    "wait-on": "9.0.5"
  },
  "build": {
    "appId": "com.reptilogic.app",
    "productName": "ReptiLogic",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  }
}
